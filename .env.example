# OpenRouter API 키 (필수) — https://openrouter.ai/keys 에서 발급
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 선택 — 기본값은 src/freerouter/config.py 참조
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# MODEL_REFRESH_TTL=600      # 무료 모델 목록 캐시 TTL(초)
# MAX_ATTEMPTS=8             # 한 요청에서 폴백으로 시도할 모델 수
# COOLDOWN_SECONDS=60        # 429 맞은 모델 제외 시간(초)
# REQUEST_TIMEOUT=120        # 업스트림 타임아웃(초)
# HOST=127.0.0.1
# PORT=8000
