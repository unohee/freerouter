# OpenRouter API key (required) — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — see src/freerouter/config.py for defaults
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# MODEL_REFRESH_TTL=600      # free-model list cache TTL (seconds)
# MAX_ATTEMPTS=8             # number of models to try as fallbacks per request
# COOLDOWN_SECONDS=60        # how long to skip a model after a 429 (seconds)
# REQUEST_TIMEOUT=120        # upstream timeout (seconds)
# HOST=127.0.0.1
# PORT=8000
